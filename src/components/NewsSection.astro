---
const newsItems = [
  {
    date: '2026年4月1日',
    category: 'お知らせ',
    title: 'ウェブサイトをリニューアルしました',
  },
  {
    date: '2026年3月15日',
    category: '物件情報',
    title: '世田谷区用賀エリアの新着物件を掲載しました',
  },
  {
    date: '2026年3月1日',
    category: 'お知らせ',
    title: '春の無料相談会を開催いたします（3月中旬〜4月）',
  },
  {
    date: '2026年2月10日',
    category: 'コラム',
    title: '不動産売却のベストタイミングについて解説します',
  },
];

const categoryColor: Record<string, string> = {
  'お知らせ': 'tag--navy',
  '物件情報': 'tag--gold',
  'コラム':   'tag--gray',
};
---

<section class="section section--bg" id="news">
  <div class="container container--narrow">
    <div class="news__head">
      <div>
        <span class="section-label">News</span>
        <h2 class="section-title">お知らせ</h2>
        <div class="divider"></div>
      </div>
    </div>

    <ul class="news-list">
      {newsItems.map((item) => (
        <li class="news-item">
          <time class="news-item__date" datetime={item.date}>{item.date}</time>
          <span class={`news-item__tag ${categoryColor[item.category] ?? 'tag--gray'}`}>
            {item.category}
          </span>
          <span class="news-item__title">{item.title}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .news__head {
    margin-bottom: var(--space-lg);
  }

  .news-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .news-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .news-item__date {
    font-family: var(--font-sans-en);
    font-size: 0.78rem;
    color: var(--color-text-light);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .news-item__tag {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 0.15em 0.7em;
    flex-shrink: 0;
  }

  .tag--navy {
    background: var(--color-navy);
    color: var(--color-white);
  }

  .tag--gold {
    background: var(--color-gold);
    color: var(--color-white);
  }

  .tag--gray {
    background: transparent;
    color: var(--color-text-mid);
    border: 1px solid var(--color-border);
  }

  .news-item__title {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .news-item {
      gap: 0.5rem;
    }

    .news-item__title {
      width: 100%;
    }
  }
</style>
