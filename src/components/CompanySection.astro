---
const companyData = [
  { label: '会社名',     value: '株式会社ピートラスト' },
  { label: '英語名',     value: 'P-TRUST CO., LTD.' },
  { label: '代表取締役', value: '山下 康太' },
  { label: '設立',       value: '—' },
  { label: '資本金',     value: '—' },
  { label: '所在地',     value: '〒157-0077 東京都世田谷区鎌田3-18-15 ロフティー玉川' },
  { label: 'TEL',        value: '03-6805-7608' },
  { label: 'FAX',        value: '03-6805-7609' },
  { label: 'MAIL',       value: 'yamashita@ptrust-web.com' },
  { label: '事業内容',   value: '不動産売買・仲介、不動産賃貸・管理、資産運用コンサルティング' },
  { label: '免許番号',   value: '—' },
  { label: '加盟団体',   value: '—' },
];
---

<section class="section section--navy company-section" id="company">
  <div class="container container--narrow">
    <div style="text-align:center">
      <span class="section-label">Company</span>
      <h2 class="section-title">会社概要</h2>
      <div class="divider divider--center"></div>
    </div>

    <table class="company-table">
      <tbody>
        {companyData.map(({ label, value }) => (
          <tr class="company-table__row">
            <th class="company-table__label">{label}</th>
            <td class="company-table__value">
              {label === 'TEL'
                ? <a href={`tel:${value.replace(/-/g, '')}`}>{value}</a>
                : label === 'MAIL'
                ? <a href={`mailto:${value}`}>{value}</a>
                : value
              }
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .company-section {
    position: relative;
    overflow: hidden;
  }

  .company-section::before {
    content: 'P-TRUST';
    position: absolute;
    font-family: var(--font-serif-en);
    font-size: clamp(6rem, 20vw, 16rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.04);
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.1em;
    line-height: 1;
  }

  .company-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--space-lg);
  }

  .company-table__row {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .company-table__row:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .company-table__label {
    font-family: var(--font-sans-ja);
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.05em;
    padding: 1.1rem var(--space-md) 1.1rem 0;
    vertical-align: top;
    white-space: nowrap;
    width: 130px;
  }

  .company-table__value {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    padding: 1.1rem 0;
    line-height: 1.7;
  }

  .company-table__value a {
    color: var(--color-gold-light);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    transition: border-color var(--transition), color var(--transition);
  }

  .company-table__value a:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 600px) {
    .company-table__label {
      width: 100px;
    }
  }
</style>
