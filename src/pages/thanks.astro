---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout
  title="送信完了 | P-TRUST 株式会社ピートラスト"
  description="お問い合わせを受け付けました。"
  noindex={true}
>
  <PageHeader
    label="Thank You"
    title="送信完了"
    breadcrumbs={[{ label: 'お問い合わせ', href: '/contact' }, { label: '送信完了' }]}
  />

  <section class="section">
    <div class="container container--narrow">
      <div class="thanks-box">
        <div class="thanks-icon" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="28" r="27" stroke="#B8965A" stroke-width="1.2"/>
            <path d="M16 28L24 36L40 20" stroke="#B8965A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h2 class="thanks-title">お問い合わせありがとうございます</h2>

        <p class="thanks-body">
          お問い合わせを受け付けました。<br />
          通常<strong>1営業日以内</strong>にご返信いたします。<br />
          しばらくお待ちください。
        </p>

        <p class="thanks-body thanks-body--note">
          お急ぎの場合は、お電話にてお問い合わせください。<br />
          <a href="tel:0368057608" class="thanks-tel">03-6805-7608</a>
          <span class="thanks-tel-note">（平日 10:00〜18:00）</span>
        </p>

        <div class="thanks-actions">
          <a href="/" class="btn btn--primary">トップページへ戻る</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks-box {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
    max-width: 560px;
    margin: 0 auto;
  }

  .thanks-icon {
    margin-bottom: var(--space-md);
  }

  .thanks-title {
    font-family: var(--font-serif-ja);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .thanks-body {
    font-size: 0.9rem;
    line-height: 2;
    color: var(--color-text-mid);
    margin-bottom: var(--space-sm);
  }

  .thanks-body strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  .thanks-body--note {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
  }

  .thanks-tel {
    font-family: var(--font-sans-en);
    font-size: 1.1rem;
    color: var(--color-navy);
    transition: color var(--transition);
  }

  .thanks-tel:hover {
    color: var(--color-gold);
  }

  .thanks-tel-note {
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-left: 0.4rem;
  }

  .thanks-actions {
    margin-top: var(--space-lg);
  }
</style>
